{
  "name": "video-splitter",
  "version": "2.0.0",
  "description": "Split video by alternating keep/skip pattern – full-featured with queue, cancel, history, tray",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/create-tray-icon.js && electron .",
    "create-icon": "node scripts/create-tray-icon.js",
    "download-ffmpeg": "node scripts/download-ffmpeg.js",
    "build:mac": "npm run create-icon && electron-builder --mac --arm64",
    "build:win": "npm run create-icon && npm run download-ffmpeg && electron-builder --win --x64",
    "build:all": "npm run create-icon && npm run download-ffmpeg && electron-builder --mac --arm64 --win --x64"
  },
  "build": {
    "appId": "com.videosplitter.app",
    "productName": "Video Splitter",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "bin/ffmpeg"
        },
        {
          "from": "node_modules/ffprobe-static/bin/darwin/arm64/ffprobe",
          "to": "bin/ffprobe"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "resources/win/ffmpeg.exe",
          "to": "bin/ffmpeg.exe"
        },
        {
          "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
          "to": "bin/ffprobe.exe"
        }
      ]
    },
    "asar": true
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  }
}
